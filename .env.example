# Example environment configuration for suedtirolmobilAI
# Copy this file to `.env` and replace the placeholder values.

# Base URL of the Mentz-EFA endpoint
EFA_BASE_URL=https://efa.sta.bz.it/apb

# API key for ChatGPT features
OPENAI_API_KEY=

# OpenAI model name for ChatGPT features
OPENAI_MODEL=o4-mini
# Maximum tokens for ChatGPT replies
OPENAI_MAX_TOKENS=120

# Token for the Telegram bot
TELEGRAM_TOKEN=

# Base URL used by the Telegram bot
API_URL=http://localhost:8000

# Log level for application logging
LOG_LEVEL=INFO

# Public URL used in /.well-known/openapi.yaml
SERVER_URL=https://api.example.com
